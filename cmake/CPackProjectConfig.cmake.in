if(NOT CPACK_BUILD_CONFIG AND NOT "@CMAKE_BUILD_TYPE@" STREQUAL "")
    set(CPACK_BUILD_CONFIG "@CMAKE_BUILD_TYPE@")
endif()

set(CMAKE_CXX_COMPILER_ARCHITECTURE_ID "@CMAKE_CXX_COMPILER_ARCHITECTURE_ID@")
if(NOT CMAKE_CXX_COMPILER_ARCHITECTURE_ID)
    set(CMAKE_CXX_COMPILER_ARCHITECTURE_ID "@CMAKE_SYSTEM_PROCESSOR@")
endif()

set(CPACK_PACKAGE_FILE_NAME
    ${CPACK_PACKAGE_NAME}-${CPACK_PACKAGE_VERSION}-@CMAKE_SYSTEM_NAME@-${CMAKE_CXX_COMPILER_ARCHITECTURE_ID}-${CPACK_BUILD_CONFIG}-@CMAKE_CXX_COMPILER_ID@-@CMAKE_CXX_COMPILER_VERSION@
)
