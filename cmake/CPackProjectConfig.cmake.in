if(NOT CPACK_BUILD_CONFIG AND NOT "@CMAKE_BUILD_TYPE@" STREQUAL "")
    set(CPACK_BUILD_CONFIG "@CMAKE_BUILD_TYPE@")
endif()
set(CPACK_PACKAGE_FILE_NAME
    ${CPACK_PACKAGE_NAME}-${CPACK_PACKAGE_VERSION}-${CPACK_SYSTEM_NAME}-@CMAKE_SYSTEM_PROCESSOR@-${CPACK_BUILD_CONFIG}-@CMAKE_CXX_COMPILER_ID@-@CMAKE_CXX_COMPILER_VERSION@
)
